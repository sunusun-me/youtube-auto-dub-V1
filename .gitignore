# =========================================================================
# 1. 核心媒体与临时数据 (Media & Temp Data)
# 针对音视频配音业务的黑洞，严禁将动辄数百MB的媒体源文件拖入 Git 仓库
# =========================================================================
*.mp4
*.wav
*.mp3
/temp/
/output/
.cache/

# =========================================================================
# 2. Python 运行与基准测试 (Python Runtime & Benchmarks)
# 清理 bench/ 目录及脚本运行产生的编译缓存
# =========================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# =========================================================================
# 3. Rust 后端构建 (Rust Backend Artifacts)
# =========================================================================
/target/
**/*.rs.bk

# =========================================================================
# 4. 前端生态与依赖 (Frontend Ecosystem)
# =========================================================================
node_modules/
frontend/dist/
frontend/.vite/
frontend/.nuxt/
.pnpm-debug.log*

# =========================================================================
# 5. 系统垃圾与归档压缩包 (System Clutter & Archives)
# =========================================================================
.DS_Store
Thumbs.db
*.zip
*.tar.gz
*.rar